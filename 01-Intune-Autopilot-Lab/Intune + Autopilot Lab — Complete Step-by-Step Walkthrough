    Write-Host "   TPM Present: $(if ($tpm.TpmPresent) {'✅ Yes'} else {'❌ No'})" -ForegroundColor $(if ($tpm.TpmPresent) {'Green'} else {'Red'})
    Write-Host "   TPM Enabled: $(if ($tpm.TpmEnabled) {'✅ Yes'} else {'❌ No'})" -ForegroundColor $(if ($tpm.TpmEnabled) {'Green'} else {'Red'})
} else {
    Write-Host "   ⚠️  Could not retrieve TPM status" -ForegroundColor Yellow
}

Write-Host ""
Write-Host "=== Check Complete ===" -ForegroundColor Cyan
Write-Host "For authoritative compliance status, check Intune:" -ForegroundColor Gray
