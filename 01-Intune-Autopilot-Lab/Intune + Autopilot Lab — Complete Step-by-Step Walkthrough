**`scripts/Force-IntuneSync.ps1`:**
```powershell
<#
.SYNOPSIS
    Forces an immediate Intune policy sync on the current device.
.DESCRIPTION
    Run this on the managed device to trigger an immediate check-in with Intune.
    Useful when testing policy changes and not wanting to wait for the default sync interval.
.NOTES
    Author: Prides Maboh
    Run as: Administrator
    Default Intune sync interval is every 8 hours; this forces it immediately.
#>

Write-Host "Triggering Intune management extension sync..." -ForegroundColor Cyan

# Method 1: Trigger via scheduled task
try {
    Get-ScheduledTask -TaskName "Schedule #3 created by enrollment client" | Start-ScheduledTask
    Write-Host "Intune sync scheduled task triggered." -ForegroundColor Green
} catch {
    Write-Host "Method 1 failed, trying Method 2..." -ForegroundColor Yellow
}

# Method 2: Restart the Intune management extension service
try {
    Restart-Service -Name "IntuneManagementExtension" -Force
    Write-Host "Intune Management Extension service restarted." -ForegroundColor Green
} catch {
    Write-Host "Method 2 failed." -ForegroundColor Yellow
}

# Method 3: Force via MDM diagnostics
Start-Process -FilePath "DeviceEnroller.exe" -ArgumentList "/o" -NoNewWindow -Wait

Write-Host ""
Write-Host "Sync triggered. Check Intune in 2-5 minutes for updated policy status." -ForegroundColor Green
Write-Host "In Intune: Devices → [Device Name] → Sync" -ForegroundColor Cyan
```

**`scripts/Check-DeviceCompliance.ps1`:**
```powershell
<#
.SYNOPSIS
    Checks the compliance status of the current device and outputs a summary.
.DESCRIPTION
    Runs locally on the managed device to check key compliance settings:
    BitLocker, Defender, Firewall, and OS version.
.NOTES
    Author: Prides Maboh
    Run as: Administrator
#>

Write-Host "=== TechCorp UK — Device Compliance Check ===" -ForegroundColor Cyan
Write-Host "Date: $(Get-Date)" -ForegroundColor Gray
Write-Host ""

# Check 1: BitLocker
Write-Host "1. BitLocker Status:" -ForegroundColor White
$bitlocker = Get-BitLockerVolume -MountPoint "C:" -ErrorAction SilentlyContinue
if ($bitlocker) {
    $status = $bitlocker.ProtectionStatus
    if ($status -eq "On") {
        Write-Host "   ✅ BitLocker is ON (Protection Status: $status)" -ForegroundColor Green
    } else {
        Write-Host "   ❌ BitLocker is OFF or SUSPENDED (Protection Status: $status)" -ForegroundColor Red
    }
} else {
    Write-Host "   ⚠️  Could not retrieve BitLocker status" -ForegroundColor Yellow
}

# Check 2: Windows Defender
Write-Host ""
Write-Host "2. Windows Defender Status:" -ForegroundColor White
$defender = Get-MpComputerStatus -ErrorAction SilentlyContinue
if ($defender) {
    Write-Host "   Antivirus Enabled: $(if ($defender.AntivirusEnabled) {'✅ Yes'} else {'❌ No'})" -ForegroundColor $(if ($defender.AntivirusEnabled) {'Green'} else {'Red'})
    Write-Host "   Real-Time Protection: $(if ($defender.RealTimeProtectionEnabled) {'✅ Yes'} else {'❌ No'})" -ForegroundColor $(if ($defender.RealTimeProtectionEnabled) {'Green'} else {'Red'})
    Write-Host "   Definitions Up to Date: $(if ($defender.AntivirusSignatureAge -le 1) {'✅ Yes'} else {"⚠️  $($defender.AntivirusSignatureAge) days old"})" -ForegroundColor $(if ($defender.AntivirusSignatureAge -le 1) {'Green'} else {'Yellow'})
} else {
    Write-Host "   ⚠️  Could not retrieve Defender status" -ForegroundColor Yellow
}

# Check 3: Firewall
Write-Host ""
Write-Host "3. Windows Firewall Status:" -ForegroundColor White
$firewall = Get-NetFirewallProfile -ErrorAction SilentlyContinue
foreach ($profile in $firewall) {
    $icon = if ($profile.Enabled) { '✅' } else { '❌' }
    $color = if ($profile.Enabled) { 'Green' } else { 'Red' }
    Write-Host "   $icon $($profile.Name) profile: $(if ($profile.Enabled) {'Enabled'} else {'Disabled'})" -ForegroundColor $color
}

# Check 4: OS Version
Write-Host ""
Write-Host "4. Operating System Version:" -ForegroundColor White
$os = Get-WmiObject Win32_OperatingSystem
Write-Host "   Version: $($os.Caption) (Build $($os.BuildNumber))" -ForegroundColor $(if ([int]$os.BuildNumber -ge 22000) {'Green'} else {'Yellow'})

# Check 5: Secure Boot
Write-Host ""
Write-Host "5. Secure Boot:" -ForegroundColor White
$secureBoot = Confirm-SecureBootUEFI -ErrorAction SilentlyContinue
Write-Host "   $(if ($secureBoot) {'✅ Secure Boot is enabled'} else {'❌ Secure Boot is disabled or not supported'})" -ForegroundColor $(if ($secureBoot) {'Green'} else {'Red'})

# Check 6: TPM
Write-Host ""
Write-Host "6. TPM Status:" -ForegroundColor White
$tpm = Get-Tpm -ErrorAction SilentlyContinue
